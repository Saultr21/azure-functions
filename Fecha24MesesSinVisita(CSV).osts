{"version":"0.3.0","body":"interface Resultado24M {\n    \"FECHA MATRICULACION\": string;\n    \"N MATRICULA\": string;\n    \"DESCRIPCION\": string;\n    \"FECHA DE SERVICIO\": string;\n    \"KILOMETRAJE ACTUAL\": number | string;\n    \"KILOMETRAJE\": number | string;\n    \"CODIGO SERVICIO\": string;\n    \"FIN MANTENIMIENTO\": string;\n    \"SALUDO\": string;\n    \"TELEFONO\": string;\n    \"EMAIL\": string;\n    \"DIRECCION\": string;\n}\n\nfunction main(workbook: ExcelScript.Workbook): {\n    result: Resultado24M[];\n    csvBase64: string;\n    CsvFileName: string;\n    logs: string[];\n} {\n    const logs: string[] = [];\n    const log = (msg: unknown): void => {\n        const text = typeof msg === \"string\" ? msg : JSON.stringify(msg);\n        logs.push(`[${new Date().toISOString()}] ${text}`);\n        console.log(text);\n    };\n\n    const hoja = workbook.getWorksheet(\"Hoja1\");\n    if (!hoja) throw new Error(\"❌ Hoja 'Hoja1' no encontrada.\");\n\n    const used = hoja.getUsedRange();\n    if (!used) throw new Error(\"❌ Hoja vacía.\");\n\n    const totalRows = used.getRowCount();\n    const totalCols = used.getColumnCount();\n\n    const encabezados = hoja\n        .getRangeByIndexes(0, 0, 1, totalCols)\n        .getValues()[0]\n        .map(v => String(v ?? \"\"));\n\n    const normalize = (s: unknown): string =>\n        s\n            ? String(s)\n                .normalize(\"NFD\")\n                .replace(/[\\u0300-\\u036f]/g, \"\")\n                .toLowerCase()\n                .trim()\n            : \"\";\n\n    const cleanModelText = (s: unknown): string =>\n        s\n            ? String(s)\n                .toLowerCase()\n                .normalize(\"NFD\")\n                .replace(/[\\u0300-\\u036f]/g, \"\")\n                .replace(/[^a-z0-9]/g, \"\")\n            : \"\";\n\n    const col = (n: string): number =>\n        encabezados.findIndex(h => normalize(h).includes(normalize(n)));\n\n    // ---------------- NUEVO: COLUMNA KM ACTUAL ----------------\n    const idxKmActual = encabezados.findIndex(\n        h => normalize(h) === normalize(\"Kilometraje\")\n    );\n\n    const idxKmMantenim = col(\"Kilometraje.mantenim\");\n\n    const idxMatricula = col(\"Nº.matrícula\");\n    const idxDescripcion = col(\"Descripción\");\n    const idxMunicipio = col(\"Direccion(3)\");\n    const idxFechaMatric = col(\"Fecha.matriculación\");\n    const idxFechaServicio = col(\"Fecha.de.servicio\");\n    const idxCodigoServ = col(\"Código.de.servicio(1)\");\n    const idxFinMantenimiento = col(\"Fin.mantenimiento\");\n    const idxSaludo = col(\"Saludo.(tratamiento)\");\n    const idxTelefono = col(\"Nº.telefono(4)\");\n    const idxEmail = col(\"Direccion.e-mail\");\n\n    const indices = [\n        idxMatricula,\n        idxDescripcion,\n        idxMunicipio,\n        idxFechaMatric,\n        idxFechaServicio,\n        idxCodigoServ,\n        idxFinMantenimiento,\n        idxKmActual,\n        idxKmMantenim,\n        idxSaludo,\n        idxTelefono,\n        idxEmail\n    ];\n\n    if (indices.some(i => i < 0))\n        throw new Error(\"❌ Faltan columnas necesarias.\");\n\n    const minCol = Math.min(...indices);\n    const maxCol = Math.max(...indices);\n    const width = maxCol - minCol + 1;\n\n    const modelosBase = [\n        \"NMAX\",\n        \"XMAX125\",\n        \"XMAX300\",\n        \"TMAX\",\n        \"MT125\",\n        \"MT07\",\n        \"MT09\",\n        \"TENERE700\"\n    ];\n    const modelosLimpios = modelosBase.map(m => cleanModelText(m));\n\n    const municipiosPermitidos = [\n        \"arucas\", \"firgas\", \"galdar\", \"ingenio\", \"moya\", \"las palmas\",\n        \"santa brigida\", \"guia\", \"telde\", \"teror\", \"valleseco\",\n        \"valsequillo\", \"vega de san mateo\"\n    ].map(m => normalize(m));\n\n    const codigosExcluidos = [\"PRE\", \"YGR\", \"YIT\"];\n\n    const hoy = new Date();\n    const fechaCorte = new Date(hoy);\n    fechaCorte.setMonth(fechaCorte.getMonth() - 24);\n\n    const fechaMinMatric = new Date(\"2019-01-01\");\n\n    const parseFecha = (v: unknown): Date | null => {\n        if (!v) return null;\n\n        if (typeof v === \"number\") {\n            const d = new Date((v - 25569) * 86400 * 1000);\n            return isNaN(d.getTime()) ? null : d;\n        }\n\n        const s = String(v).trim();\n        if (!s || s === \"--/--/--\") return null;\n\n        const parts = s.split(\"/\");\n        if (parts.length === 3) {\n            const [d, m, y] = parts.map(n => parseInt(n, 10));\n            const date = new Date(y, m - 1, d);\n            return isNaN(date.getTime()) ? null : date;\n        }\n\n        const parsed = new Date(s);\n        return isNaN(parsed.getTime()) ? null : parsed;\n    };\n\n    const CHUNK = 500;\n    const visitasPorMatricula = new Map<string, Resultado24M[]>();\n\n    for (let start = 1; start < totalRows; start += CHUNK) {\n        const rows = Math.min(CHUNK, totalRows - start);\n        const chunk = hoja.getRangeByIndexes(start, minCol, rows, width).getValues() as unknown[][];\n\n        for (const fila of chunk) {\n            const matricula = String(fila[idxMatricula - minCol] ?? \"\").trim();\n            if (!matricula) continue;\n\n            const modeloClean = cleanModelText(fila[idxDescripcion - minCol]);\n            if (!modelosLimpios.some(m => modeloClean.includes(m))) continue;\n\n            const municipioNorm = normalize(fila[idxMunicipio - minCol]);\n            if (!municipiosPermitidos.some(m => municipioNorm.includes(m))) continue;\n\n            const fechaMat = parseFecha(fila[idxFechaMatric - minCol]);\n            const fechaServ = parseFecha(fila[idxFechaServicio - minCol]);\n            const fechaFinMant = parseFecha(fila[idxFinMantenimiento - minCol]);\n\n            if (!fechaMat || !fechaServ) continue;\n            if (fechaMat < fechaMinMatric) continue;\n\n            const codServ = String(fila[idxCodigoServ - minCol] ?? \"\").trim().toUpperCase();\n\n            // KM ACTUAL & KM MANTENIMIENTO\n            const rawKmActual = fila[idxKmActual - minCol];\n            const rawKmMantenim = fila[idxKmMantenim - minCol];\n\n            const kmActual: string | number =\n                typeof rawKmActual === \"boolean\"\n                    ? \"\"\n                    : (rawKmActual as string | number) ?? \"\";\n\n            const kmMantenim: string | number =\n                typeof rawKmMantenim === \"boolean\"\n                    ? \"\"\n                    : (rawKmMantenim as string | number) ?? \"\";\n\n\n            const reg: Resultado24M = {\n                \"FECHA MATRICULACION\": fechaMat.toISOString().split(\"T\")[0],\n                \"N MATRICULA\": matricula,\n                \"DESCRIPCION\": String(fila[idxDescripcion - minCol] ?? \"\"),\n                \"FECHA DE SERVICIO\": fechaServ.toISOString().split(\"T\")[0],\n                \"KILOMETRAJE ACTUAL\": kmActual,\n                \"KILOMETRAJE\": kmMantenim,\n                \"CODIGO SERVICIO\": codServ,\n                \"FIN MANTENIMIENTO\": fechaFinMant ? fechaFinMant.toISOString().split(\"T\")[0] : \"\",\n                \"SALUDO\": String(fila[idxSaludo - minCol] ?? \"\"),\n                \"TELEFONO\": String(fila[idxTelefono - minCol] ?? \"\"),\n                \"EMAIL\": String(fila[idxEmail - minCol] ?? \"\"),\n                \"DIRECCION\": municipioNorm,\n            };\n\n            if (!visitasPorMatricula.has(matricula)) visitasPorMatricula.set(matricula, []);\n            visitasPorMatricula.get(matricula)!.push(reg);\n        }\n    }\n\n    const dedupe: Resultado24M[] = [];\n\n    for (const visitas of Array.from(visitasPorMatricula.values())) {\n        let ultima = visitas[0];\n\n        for (const v of visitas) {\n            const f1 = new Date(v[\"FECHA DE SERVICIO\"]).getTime();\n            const f2 = new Date(ultima[\"FECHA DE SERVICIO\"]).getTime();\n            if (f1 > f2) ultima = v;\n        }\n\n        dedupe.push(ultima);\n    }\n\n    const final: Resultado24M[] = [];\n\n    for (const r of dedupe) {\n        const fServ = new Date(r[\"FECHA DE SERVICIO\"]);\n\n        if (fServ > fechaCorte) continue;\n        if (codigosExcluidos.includes(r[\"CODIGO SERVICIO\"])) continue;\n\n        final.push(r);\n    }\n\n    final.sort(\n        (a, b) =>\n            new Date(a[\"FECHA DE SERVICIO\"]).getTime() -\n            new Date(b[\"FECHA DE SERVICIO\"]).getTime()\n    );\n\n    log(`📌 Resultados obtenidos: ${final.length}`);\n\n    // === CSV ===  \n    const headers = [\n        \"FECHA MATRICULACION\",\n        \"N MATRICULA\",\n        \"DESCRIPCION\",\n        \"FECHA DE SERVICIO\",\n        \"KILOMETRAJE ULTIMO SERVICIO\",\n        \"CODIGO SERVICIO\",\n        \"KILOMETRAJE MANTENIMIENTO\",\n        \"FIN MANTENIMIENTO\",\n        \"SALUDO\",\n        \"TELEFONO\",\n        \"EMAIL\",\n        \"DIRECCION\",\n    ];\n\n    const csvRows = [headers.join(\";\")];\n\n    final.forEach(r => {\n        const rec = r as unknown as Record<string, string | number | boolean | null>;\n\n        csvRows.push([\n            r[\"FECHA MATRICULACION\"],\n            r[\"N MATRICULA\"],\n            r[\"DESCRIPCION\"],\n            r[\"FECHA DE SERVICIO\"],\n            r[\"KILOMETRAJE ACTUAL\"],   // ← mapeado\n            r[\"KILOMETRAJE\"],          // ← mapeado\n            r[\"CODIGO SERVICIO\"],\n            r[\"FIN MANTENIMIENTO\"],\n            r[\"SALUDO\"],\n            r[\"TELEFONO\"],\n            r[\"EMAIL\"],\n            r[\"DIRECCION\"],\n        ].map(x => String(x ?? \"\").replace(/;/g, \",\")).join(\";\"));\n    });\n\n\n    const csvContent = csvRows.join(\"\\n\");\n    const csvBase64 = base64Encode(csvContent);\n    const CsvFileName = `FiltradoInactivos24M_${new Date().toISOString().split(\"T\")[0]}.csv`;\n\n    return { result: final, csvBase64, CsvFileName, logs };\n}\n\nfunction base64Encode(str: string): string {\n    const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\";\n    let output = \"\";\n    let i = 0;\n    while (i < str.length) {\n        const c1 = str.charCodeAt(i++);\n        const c2 = str.charCodeAt(i++);\n        const c3 = str.charCodeAt(i++);\n        const e1 = c1 >> 2;\n        const e2 = ((c1 & 3) << 4) | (c2 >> 4);\n        const e3 = ((c2 & 15) << 2) | (c3 >> 6);\n        const e4 = c3 & 63;\n        if (isNaN(c2)) output += chars.charAt(e1) + chars.charAt(e2) + \"==\";\n        else if (isNaN(c3)) output += chars.charAt(e1) + chars.charAt(e2) + chars.charAt(e3) + \"=\";\n        else output += chars.charAt(e1) + chars.charAt(e2) + chars.charAt(e3) + chars.charAt(e4);\n    }\n    return output;\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"FECHA MATRICULACION\":{\"type\":\"string\"},\"N MATRICULA\":{\"type\":\"string\"},\"DESCRIPCION\":{\"type\":\"string\"},\"FECHA DE SERVICIO\":{\"type\":\"string\"},\"KILOMETRAJE ACTUAL\":{},\"KILOMETRAJE\":{},\"CODIGO SERVICIO\":{\"type\":\"string\"},\"FIN MANTENIMIENTO\":{\"type\":\"string\"},\"SALUDO\":{\"type\":\"string\"},\"TELEFONO\":{\"type\":\"string\"},\"EMAIL\":{\"type\":\"string\"},\"DIRECCION\":{\"type\":\"string\"}}}},\"csvBase64\":{\"type\":\"string\"},\"CsvFileName\":{\"type\":\"string\"},\"logs\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}