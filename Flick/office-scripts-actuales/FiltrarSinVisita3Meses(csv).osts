{"version":"0.3.0","body":"interface Resultado3M {\n    \"FECHA MATRICULACION\": string;\n    \"N MATRICULA\": string;\n    \"DESCRIPCION\": string;\n    \"FECHA DE SERVICIO\": string;\n    \"KILOMETRAJE ULTIMO SERVICIO\": number | string;\n    \"CODIGO SERVICIO\": string;\n    \"KILOMETRAJE MANTENIMIENTO\": number | string;\n    \"FIN MANTENIMIENTO\": string;\n    \"SALUDO\": string;\n    \"TELEFONO\": string;\n    \"EMAIL\": string;\n    \"DIRECCION\": string;\n}\n\nfunction main(workbook: ExcelScript.Workbook): { csvBase64: string; logs: string[] } {\n\n    const logs: string[] = [];\n    const log = (m: unknown) => {\n        const t = typeof m === \"string\" ? m : JSON.stringify(m);\n        logs.push(`[${new Date().toISOString()}] ${t}`);\n        console.log(t);\n    };\n\n    const hoja = workbook.getWorksheet(\"Hoja1\");\n    if (!hoja) throw new Error(\"❌ Hoja 'Hoja1' no encontrada.\");\n\n    const used = hoja.getUsedRange();\n    if (!used) throw new Error(\"❌ La hoja está vacía.\");\n\n    const totalRows = used.getRowCount();\n    const totalCols = used.getColumnCount();\n\n    const normalize = (s: unknown): string =>\n        s ? String(s).normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").toLowerCase().trim() : \"\";\n\n    const cleanModel = (s: unknown): string =>\n        s ? String(s).toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").replace(/[^a-z0-9]/g, \"\") : \"\";\n\n    const parseFecha = (v: unknown): Date | null => {\n        if (!v || v === \"--/--/--\") return null;\n\n        if (typeof v === \"number\") {\n            const d = new Date((v - 25569) * 86400 * 1000);\n            return isNaN(d.getTime()) ? null : d;\n        }\n\n        const s = String(v).trim();\n        const p = s.split(\"/\");\n        if (p.length === 3) {\n            const d = parseInt(p[0], 10);\n            const m = parseInt(p[1], 10) - 1;\n            const y = parseInt(p[2], 10);\n            const dt = new Date(y, m, d);\n            return isNaN(dt.getTime()) ? null : dt;\n        }\n\n        const dt = new Date(s);\n        return isNaN(dt.getTime()) ? null : dt;\n    };\n\n    const encabezados = hoja.getRangeByIndexes(0, 0, 1, totalCols)\n        .getValues()[0]\n        .map(v => String(v ?? \"\"));\n\n    const col = (n: string): number =>\n        encabezados.findIndex(h => normalize(h).includes(normalize(n)));\n\n    const colExact = (n: string): number =>\n        encabezados.findIndex(h => normalize(h) === normalize(n));\n\n    const idxMatricula = col(\"Nº.matrícula\");\n    const idxDesc = col(\"Descripción\");\n    const idxMunicipio = col(\"Direccion(3)\");\n    const idxFechaMat = col(\"Fecha.matriculación\");\n    const idxFechaServ = col(\"Fecha.de.servicio\");\n    const idxCodigoServ = col(\"Código.de.servicio(1)\");\n    const idxFinMant = col(\"Fin.mantenimiento\");\n    const idxKmUltimo = colExact(\"Kilometraje\");\n    const idxKmMant = col(\"Kilometraje.mantenim\");\n    const idxSaludo = col(\"Saludo.(tratamiento)\");\n    const idxTelefono = col(\"Nº.telefono(4)\");\n    const idxEmail = col(\"Direccion.e-mail\");\n\n    const required = [\n        idxMatricula, idxDesc, idxMunicipio, idxFechaMat,\n        idxFechaServ, idxCodigoServ, idxFinMant,\n        idxKmUltimo, idxKmMant, idxSaludo, idxTelefono, idxEmail\n    ];\n\n    if (required.some(i => i < 0)) {\n        throw new Error(\"❌ Faltan columnas necesarias.\");\n    }\n\n    const minCol = Math.min(...required);\n    const maxCol = Math.max(...required);\n    const width = maxCol - minCol + 1;\n\n    const modelos = [\"nmax\", \"xmax125\", \"xmax300\", \"tmax\", \"mt125\", \"mt07\", \"mt09\", \"tenere700\"];\n\n    const municipios = [\n        \"arucas\", \"firgas\", \"galdar\", \"ingenio\", \"moya\",\n        \"las palmas\", \"santa brigida\", \"guia\", \"telde\",\n        \"teror\", \"valleseco\", \"valsequillo\", \"vega de san mateo\"\n    ];\n\n    const hoy = new Date();\n    const fechaLimite = new Date(hoy);\n    fechaLimite.setMonth(fechaLimite.getMonth() - 3);\n\n    const visitas = new Map<string, Resultado3M[]>();\n    const CHUNK = 500;\n\n    for (let start = 1; start < totalRows; start += CHUNK) {\n        const rows = Math.min(CHUNK, totalRows - start);\n        const chunk = hoja.getRangeByIndexes(start, minCol, rows, width).getValues() as unknown[][];\n\n        for (const fila of chunk) {\n            const matricula = String(fila[idxMatricula - minCol] ?? \"\").trim();\n            if (!matricula) continue;\n\n            const descClean = cleanModel(fila[idxDesc - minCol]);\n            if (!modelos.some(m => descClean.includes(m))) continue;\n\n            const municipio = normalize(fila[idxMunicipio - minCol]);\n            if (!municipios.some(m => municipio.includes(m))) continue;\n\n            const fechaMat = parseFecha(fila[idxFechaMat - minCol]);\n            if (!fechaMat) continue;\n\n            const fechaServ = parseFecha(fila[idxFechaServ - minCol]);\n            if (!fechaServ) continue;\n\n            const kmUlt = fila[idxKmUltimo - minCol];\n            const kmMant = fila[idxKmMant - minCol];\n            const finMant = parseFecha(fila[idxFinMant - minCol]);\n\n            const reg: Resultado3M = {\n                \"FECHA MATRICULACION\": fechaMat.toISOString().split(\"T\")[0],\n                \"N MATRICULA\": matricula,\n                \"DESCRIPCION\": String(fila[idxDesc - minCol] ?? \"\"),\n                \"FECHA DE SERVICIO\": fechaServ.toISOString().split(\"T\")[0],\n                \"KILOMETRAJE ULTIMO SERVICIO\": typeof kmUlt === \"number\" ? kmUlt : String(kmUlt ?? \"\"),\n                \"CODIGO SERVICIO\": String(fila[idxCodigoServ - minCol] ?? \"\"),\n                \"KILOMETRAJE MANTENIMIENTO\": typeof kmMant === \"number\" ? kmMant : String(kmMant ?? \"\"),\n                \"FIN MANTENIMIENTO\": finMant ? finMant.toISOString().split(\"T\")[0] : \"\",\n                \"SALUDO\": String(fila[idxSaludo - minCol] ?? \"\"),\n                \"TELEFONO\": String(fila[idxTelefono - minCol] ?? \"\"),\n                \"EMAIL\": String(fila[idxEmail - minCol] ?? \"\"),\n                \"DIRECCION\": String(fila[idxMunicipio - minCol] ?? \"\")\n            };\n\n            if (!visitas.has(matricula)) visitas.set(matricula, []);\n            visitas.get(matricula)!.push(reg);\n        }\n    }\n\n    const finales: Resultado3M[] = [];\n    const matrList = Array.from(visitas.keys());\n\n    for (const matricula of matrList) {\n        const lista = visitas.get(matricula)!;\n\n        let ultima = lista[0];\n        for (const v of lista) {\n            if (new Date(v[\"FECHA DE SERVICIO\"]) > new Date(ultima[\"FECHA DE SERVICIO\"])) {\n                ultima = v;\n            }\n        }\n\n        const fechaMat = new Date(ultima[\"FECHA MATRICULACION\"]);\n        const fechaServ = new Date(ultima[\"FECHA DE SERVICIO\"]);\n        const kmUlt = Number(ultima[\"KILOMETRAJE ULTIMO SERVICIO\"]);\n\n        if (fechaMat > fechaLimite) continue;\n        if (fechaServ > fechaLimite) continue;\n        if (kmUlt >= 200) continue;\n\n        finales.push(ultima);\n    }\n\n    log(`📌 Registros finales: ${finales.length}`);\n    if (finales.length === 0) throw new Error(\"❌ No se encontraron registros válidos.\");\n\n    const headers = [\n        \"FECHA MATRICULACION\",\n        \"N MATRICULA\",\n        \"DESCRIPCION\",\n        \"FECHA DE SERVICIO\",\n        \"KILOMETRAJE ULTIMO SERVICIO\",\n        \"CODIGO SERVICIO\",\n        \"KILOMETRAJE MANTENIMIENTO\",\n        \"FIN MANTENIMIENTO\",\n        \"SALUDO\",\n        \"TELEFONO\",\n        \"EMAIL\",\n        \"DIRECCION\"\n    ];\n\n    const csvRows: string[] = [headers.join(\";\")];\n\n    for (const r of finales) {\n        const rec = (r as unknown) as Record<string, string | number | null | undefined>;\n\n        csvRows.push(\n            headers.map(h => String(rec[h] ?? \"\").replace(/;/g, \",\")).join(\";\")\n        );\n\n    }\n\n    const csvBase64 = base64Encode(csvRows.join(\"\\n\"));\n    return { csvBase64, logs };\n}\n\nfunction base64Encode(str: string): string {\n    const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\";\n    let out = \"\", i = 0;\n    while (i < str.length) {\n        const c1 = str.charCodeAt(i++);\n        const c2 = str.charCodeAt(i++);\n        const c3 = str.charCodeAt(i++);\n        const e1 = c1 >> 2;\n        const e2 = ((c1 & 3) << 4) | (c2 >> 4);\n        const e3 = ((c2 & 15) << 2) | (c3 >> 6);\n        const e4 = c3 & 63;\n        if (isNaN(c2)) out += chars[e1] + chars[e2] + \"==\";\n        else if (isNaN(c3)) out += chars[e1] + chars[e2] + chars[e3] + \"=\";\n        else out += chars[e1] + chars[e2] + chars[e3] + chars[e4];\n    }\n    return out;\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"csvBase64\":{\"type\":\"string\"},\"logs\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}