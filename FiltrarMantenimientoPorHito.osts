{"version":"0.3.0","body":"/**\n * Filtra motos próximas al siguiente hito para un modelo concreto,\n * usando SOLO la columna \"Descripción\" en Hoja1\n * y la hoja \"ResultadosMediasHitos\" para los hitos.\n */\n\ninterface RegistroServicio {\n    matricula: string;\n    modelo: string;\n    km: number;\n    fechaServ: Date;\n    fechaMat: Date;\n    saludo: string;\n    telefono: string;\n    email: string;\n    direccion: string;\n    codigoServ: string; // ⭐ AÑADIDO\n}\n\ninterface MotoSalida {\n    \"Fecha matriculacion\": string;\n    Matricula: string;\n    Modelo: string;\n    Saludo: string;\n    Telefono: string;\n    Email: string;\n    Direccion: string;\n    \"Fecha último servicio\": string;\n    \"Kilometraje último servicio\": number;\n    \"Codigo servicio\": string; // ⭐ AÑADIDO (posición correcta)\n    \"Meses desde último servicio\": string;\n    \"Próximo hito (km)\": number;\n}\n\nfunction main(\n    workbook: ExcelScript.Workbook,\n    modeloObjetivo: string,\n    hitoActual: number\n): { csvBase64: string; log: string } {\n\n    const normalizeStrict = (v: unknown): string =>\n        v\n            ? String(v)\n                .normalize(\"NFD\")\n                .replace(/[\\u0300-\\u036f]/g, \"\")\n                .replace(/[^a-zA-Z0-9]/g, \"\")\n                .toLowerCase()\n            : \"\";\n\n    const parseFecha = (v: unknown): Date | null => {\n        if (!v || v === \"--/--/--\") return null;\n        if (typeof v === \"number\") return new Date((v - 25569) * 86400 * 1000);\n        const s = String(v).trim();\n        const p = s.split(\"/\");\n        if (p.length === 3) return new Date(Number(p[2]), Number(p[1]) - 1, Number(p[0]));\n        const f = new Date(s);\n        return isNaN(f.getTime()) ? null : f;\n    };\n\n    const diffMeses = (a: Date, b: Date): number =>\n        (b.getTime() - a.getTime()) / (1000 * 60 * 60 * 24 * 30.4375);\n\n    const base64Encode = (str: string): string => {\n        const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\";\n        let res = \"\", i = 0;\n        while (i < str.length) {\n            const c1 = str.charCodeAt(i++), c2 = str.charCodeAt(i++), c3 = str.charCodeAt(i++);\n            const e1 = c1 >> 2, e2 = ((c1 & 3) << 4) | (c2 >> 4);\n            const e3 = ((c2 & 15) << 2) | (c3 >> 6), e4 = c3 & 63;\n            if (isNaN(c2)) res += chars[e1] + chars[e2] + \"==\";\n            else if (isNaN(c3)) res += chars[e1] + chars[e2] + chars[e3] + \"=\";\n            else res += chars[e1] + chars[e2] + chars[e3] + chars[e4];\n        }\n        return res;\n    };\n\n    const modeloClave = normalizeStrict(modeloObjetivo);\n\n    // ===================== LEER RESULTADOSMEDIASHITOS =====================\n    const hojaRes = workbook.getWorksheet(\"ResultadosMediasHitos\");\n    const usedRes = hojaRes.getUsedRange();\n    const valoresRes = usedRes.getValues() as unknown[][];\n    const headersRes = valoresRes[0] as string[];\n\n    const idxModeloRes = headersRes.indexOf(\"MODELO\");\n    const idxHitoRes = headersRes.indexOf(\"HITO (KM)\");\n    const idxMediaRes = headersRes.indexOf(\"MEDIA (MESES)\");\n\n    if (idxModeloRes === -1 || idxHitoRes === -1 || idxMediaRes === -1) {\n        const msg =\n            \"⚠ No se han encontrado columnas MODELO / HITO (KM) / MEDIA (MESES) en ResultadosMediasHitos.\";\n        return { csvBase64: base64Encode(\"\"), log: msg };\n    }\n\n    const hitosModelo = valoresRes\n        .slice(1)\n        .filter(r => normalizeStrict(r[idxModeloRes]).includes(modeloClave))\n        .map(r => ({\n            hito: Number(r[idxHitoRes]),\n            media: Number(r[idxMediaRes])\n        }))\n        .filter(h => !isNaN(h.hito) && !isNaN(h.media))\n        .sort((a, b) => a.hito - b.hito);\n\n    if (hitosModelo.length === 0) {\n        const msg = `⚠ No se han encontrado hitos para el modelo \"${modeloObjetivo}\"`;\n        return { csvBase64: base64Encode(\"\"), log: msg };\n    }\n\n    let hitoAnterior = 0;\n    let hitoSiguiente = 0;\n    let mediaSiguiente = 0;\n\n    for (const h of hitosModelo) {\n        if (h.hito <= hitoActual) hitoAnterior = h.hito;\n        else if (hitoSiguiente === 0) {\n            hitoSiguiente = h.hito;\n            mediaSiguiente = h.media;\n        }\n    }\n\n    if (hitoSiguiente === 0) {\n        const msg = `⚠ No se ha encontrado siguiente hito para ${hitoActual} km`;\n        return { csvBase64: base64Encode(\"\"), log: msg };\n    }\n\n    // ===================== LEER \"Hoja1\" =====================\n    const hojaBase = workbook.getWorksheet(\"Hoja1\");\n    const usedBase = hojaBase.getUsedRange();\n    const totalRows = usedBase.getRowCount();\n    const totalCols = usedBase.getColumnCount();\n\n    const headerRow = hojaBase.getRangeByIndexes(0, 0, 1, totalCols).getValues()[0] as string[];\n\n    const idxDesc = headerRow.indexOf(\"Descripción\");\n    const idxMatric = headerRow.indexOf(\"Nº.matrícula\");\n    const idxFechaServ = headerRow.indexOf(\"Fecha.de.servicio\");\n    const idxFechaMat = headerRow.indexOf(\"Fecha.matriculación\");\n    const idxKm = headerRow.indexOf(\"Kilometraje\");\n    const idxCodServ = headerRow.indexOf(\"Código.de.servicio(1)\"); // ⭐ NUEVA COLUMNA\n\n    const idxSaludo = headerRow.indexOf(\"Saludo.(tratamiento)\");\n    const idxTelef = headerRow.indexOf(\"Nº.telefono(4)\");\n    const idxMail = headerRow.indexOf(\"Direccion.e-mail\");\n    const idxDire = headerRow.indexOf(\"Direccion(3)\");\n\n    if (\n        idxDesc === -1 ||\n        idxMatric === -1 ||\n        idxFechaServ === -1 ||\n        idxFechaMat === -1 ||\n        idxKm === -1\n    ) {\n        const msg = \"⚠ Faltan columnas obligatorias en Hoja1.\";\n        return { csvBase64: base64Encode(\"\"), log: msg };\n    }\n\n    const registros = new Map<string, RegistroServicio>();\n    const CHUNK = 500;\n    const hoy = new Date();\n\n    for (let start = 1; start < totalRows; start += CHUNK) {\n        const rows = Math.min(CHUNK, totalRows - start);\n\n        const data = hojaBase\n            .getRangeByIndexes(start, 0, rows, totalCols)\n            .getValues() as unknown[][];\n\n        for (const fila of data) {\n            const descNorm = normalizeStrict(fila[idxDesc] ?? \"\");\n            if (!descNorm.includes(modeloClave)) continue;\n\n            const matricula = String(fila[idxMatric] ?? \"\").trim();\n            if (!matricula) continue;\n\n            const fechaServ = parseFecha(fila[idxFechaServ]);\n            const fechaMat = parseFecha(fila[idxFechaMat]);\n            if (!fechaServ || !fechaMat) continue;\n\n            const km = Number(fila[idxKm]);\n            if (isNaN(km) || km <= 0) continue;\n\n            const codigoServ = idxCodServ === -1 ? \"\" : String(fila[idxCodServ] ?? \"\"); // ⭐ NUEVO\n\n            const existente = registros.get(matricula);\n            if (!existente || fechaServ > existente.fechaServ) {\n                registros.set(matricula, {\n                    matricula,\n                    modelo: String(fila[idxDesc] ?? \"\"),\n                    km,\n                    fechaServ,\n                    fechaMat,\n                    saludo: idxSaludo === -1 ? \"\" : String(fila[idxSaludo] ?? \"\"),\n                    telefono: idxTelef === -1 ? \"\" : String(fila[idxTelef] ?? \"\"),\n                    email: idxMail === -1 ? \"\" : String(fila[idxMail] ?? \"\"),\n                    direccion: idxDire === -1 ? \"\" : String(fila[idxDire] ?? \"\"),\n                    codigoServ // ⭐ GUARDAMOS EL CÓDIGO DE SERVICIO\n                });\n            }\n        }\n    }\n\n    // ===================== FILTRAR MANTENIMIENTO PENDIENTE =====================\n    const resultado: MotoSalida[] = [];\n\n    for (const r of Array.from(registros.values())) {\n\n        if (r.km < hitoAnterior || r.km >= hitoSiguiente) continue;\n\n        const meses = diffMeses(r.fechaServ, hoy);\n\n        if (meses >= mediaSiguiente - 6) {\n            resultado.push({\n                \"Fecha matriculacion\": r.fechaMat.toISOString().split(\"T\")[0],\n                Matricula: r.matricula,\n                Modelo: r.modelo,\n                Saludo: r.saludo,\n                Telefono: r.telefono,\n                Email: r.email,\n                Direccion: r.direccion,\n                \"Fecha último servicio\": r.fechaServ.toISOString().split(\"T\")[0],\n                \"Kilometraje último servicio\": r.km,\n                \"Codigo servicio\": r.codigoServ, // ⭐ AÑADIDA EN EL ORDEN CORRECTO\n                \"Meses desde último servicio\": meses.toFixed(1).replace(\".\", \",\"),\n                \"Próximo hito (km)\": hitoSiguiente\n            });\n        }\n    }\n\n    // ===================== CSV =====================\n    let csv = \"\";\n    let logMessage = \"\";\n\n    if (resultado.length > 0) {\n        // ----------------- CSV FINAL ORDENADO -----------------\n        const headersCsv = [\n            \"Fecha matriculacion\",\n            \"Matricula\",\n            \"Modelo\",\n            \"Fecha último servicio\",\n            \"Kilometraje último servicio\",\n            \"Codigo servicio\",\n            \"Meses desde último servicio\",\n            \"Próximo hito (km)\",\n            \"Saludo\",\n            \"Telefono\",\n            \"Email\",\n            \"Direccion\"\n        ];\n\n        csv = [\n            headersCsv.join(\";\"),\n            ...resultado.map(r =>\n                headersCsv\n                    .map(h => String((r as unknown as Record<string, unknown>)[h] ?? \"\").replace(/;/g, \",\"))\n                    .join(\";\")\n            )\n        ].join(\"\\n\");\n\n\n        logMessage = `✔ ${resultado.length} motos del modelo \"${modeloObjetivo}\" próximas al hito ${hitoSiguiente} km.`;\n    } else {\n        logMessage = `ℹ No se han encontrado motos del modelo \"${modeloObjetivo}\" próximas al hito ${hitoSiguiente} km.`;\n    }\n\n    return {\n        csvBase64: base64Encode(csv),\n        log: logMessage\n    };\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[{\"name\":\"modeloObjetivo\",\"index\":0},{\"name\":\"hitoActual\",\"index\":1}],\"parameterSchema\":{\"type\":\"object\",\"required\":[\"modeloObjetivo\",\"hitoActual\"],\"properties\":{\"modeloObjetivo\":{\"type\":\"string\"},\"hitoActual\":{\"type\":\"number\"}}},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"csvBase64\":{\"type\":\"string\"},\"log\":{\"type\":\"string\"}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"},{\"name\":\"modeloObjetivo\",\"comment\":\"\"},{\"name\":\"hitoActual\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}