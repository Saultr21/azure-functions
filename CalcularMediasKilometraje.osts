{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\n    /**\n     * CONFIGURACIÓN\n     */\n    const MODELOS: string[] = [\n        \"NMAX\",\n        \"XMAX125\",\n        \"XMAX300\",\n        \"TMAX\",\n        \"MT125\",\n        \"MT07\",\n        \"MT09\",\n        \"TENERE700\"\n    ];\n\n    /** \n     * NUEVO: hitos por modelo \n     */\n    const HITOS_POR_MODELO: { [modelo: string]: number[] } = {\n        // Grupo 1\n        \"NMAX\": [1000, 4000, 7000, 10000, 13000, 16000, 19000],\n        \"XMAX125\": [1000, 4000, 7000, 10000, 13000, 16000, 19000],\n        \"MT125\": [1000, 4000, 7000, 10000, 13000, 16000, 19000],\n\n        // Grupo 2\n        \"XMAX300\": [1000, 5000, 10000, 15000, 20000],\n        \"TMAX\": [1000, 5000, 10000, 15000, 20000],\n        \"MT07\": [1000, 5000, 100000, 15000, 20000],\n        \"TENERE700\": [1000, 5000, 10000, 15000, 20000],\n        \"MT09\": [1000, 5000, 10000, 15000, 20000]\n    };\n\n    const MIN_KM_POR_ANO = 1000; // filtro de uso mínimo\n\n    const hoja = workbook.getWorksheet(\"Hoja1\");\n    if (!hoja) throw new Error(\"❌ No existe la hoja 'Hoja1'.\");\n\n    const usedRange = hoja.getUsedRange();\n    if (!usedRange) throw new Error(\"❌ No hay datos en la hoja.\");\n\n    const totalRows = usedRange.getRowCount();\n    const totalCols = usedRange.getColumnCount();\n\n    /** UTILIDADES **/\n    const normalizeHeader = (v: string): string =>\n        v\n            .normalize(\"NFD\")\n            .replace(/[\\u0300-\\u036f]/g, \"\")\n            .toLowerCase()\n            .replace(/[^a-z0-9]/g, \"\")\n            .trim();\n\n    const cleanModelText = (v: unknown): string => {\n        if (v === null || v === undefined) return \"\";\n        return String(v)\n            .toLowerCase()\n            .normalize(\"NFD\")\n            .replace(/[\\u0300-\\u036f]/g, \"\")\n            .replace(/[^a-z0-9]/g, \"\");\n    };\n\n    const parseDate = (v: unknown): Date | null => {\n        if (v === null || v === undefined || v === \"\" || v === \"--/--/--\") return null;\n\n        if (typeof v === \"number\") {\n            return new Date(Math.round((v - 25569) * 86400 * 1000));\n        }\n\n        const s = String(v).trim();\n        if (!s) return null;\n\n        const iso = Date.parse(s);\n        if (!isNaN(iso)) return new Date(iso);\n\n        const parts = s.split(/[\\/\\-]/);\n        if (parts.length === 3) {\n            let d = parseInt(parts[0], 10);\n            let m = parseInt(parts[1], 10);\n            let y = parseInt(parts[2], 10);\n            if (isNaN(d) || isNaN(m) || isNaN(y)) return null;\n            if (y < 100) y += 2000;\n            return new Date(y, m - 1, d);\n        }\n\n        return null;\n    };\n\n    /** LOCALIZAR COLUMNAS */\n    const headerRow = hoja.getRangeByIndexes(0, 0, 1, totalCols).getValues()[0];\n    const headers: string[] = headerRow.map((v) => String(v ?? \"\"));\n\n    const col = (name: string): number => {\n        const target = normalizeHeader(name);\n        for (let i = 0; i < headers.length; i++) {\n            const hNorm = normalizeHeader(headers[i]);\n            if (hNorm.includes(target)) return i;\n        }\n        return -1;\n    };\n\n    const idxMatricula = col(\"matr\");\n    const idxDesc = col(\"descrip\");\n    const idxFechaMat = col(\"fecha.matricul\");\n    const idxFechaServ = col(\"fecha.de.servic\");\n\n    let idxKm = -1;\n    for (let i = 0; i < headers.length; i++) {\n        const hNorm = normalizeHeader(headers[i]);\n        if (hNorm === \"kilometraje\") {\n            idxKm = i;\n            break;\n        }\n    }\n    if (idxKm === -1) {\n        idxKm = col(\"kilometraje\");\n    }\n\n    if (\n        idxMatricula < 0 ||\n        idxDesc < 0 ||\n        idxFechaMat < 0 ||\n        idxFechaServ < 0 ||\n        idxKm < 0\n    ) {\n        throw new Error(\n            \"❌ No se encontraron columnas necesarias.\"\n        );\n    }\n\n    /** DEFINICIÓN DE REGISTRO */\n    interface Registro {\n        modelo: string;\n        matricula: string;\n        km: number;\n        fechaMat: Date;\n        fechaServ: Date;\n        kmPorMes: number;\n    }\n\n    const registros: Registro[] = [];\n    const CHUNK = 500;\n\n    /** LECTURA */\n    for (let start = 1; start < totalRows; start += CHUNK) {\n        const rows = Math.min(CHUNK, totalRows - start);\n        const chunk = hoja\n            .getRangeByIndexes(start, 0, rows, totalCols)\n            .getValues() as (string | number | boolean | null)[][];\n\n        for (const fila of chunk) {\n            const matriculaRaw = fila[idxMatricula];\n            const descRaw = fila[idxDesc];\n            const kmRaw = fila[idxKm];\n            const fechaMatRaw = fila[idxFechaMat];\n            const fechaServRaw = fila[idxFechaServ];\n\n            const matricula = String(matriculaRaw ?? \"\").trim();\n            if (!matricula) continue;\n\n            const fechaMat = parseDate(fechaMatRaw);\n            const fechaServ = parseDate(fechaServRaw);\n            if (!fechaMat || !fechaServ) continue;\n\n            const km = Number(kmRaw);\n            if (isNaN(km) || km <= 0) continue;\n\n            const descClean = cleanModelText(descRaw);\n            let modeloDetectado = \"\";\n            for (const modelo of MODELOS) {\n                const mClean = cleanModelText(modelo);\n                if (descClean.includes(mClean)) {\n                    modeloDetectado = modelo;\n                    break;\n                }\n            }\n            if (!modeloDetectado) continue;\n\n            const diffMs = fechaServ.getTime() - fechaMat.getTime();\n            const diffMeses = diffMs / (1000 * 60 * 60 * 24 * 30.4375);\n            if (diffMeses <= 0) continue;\n\n            const kmPorMes = km / diffMeses;\n            const kmPorAno = kmPorMes * 12;\n\n            if (kmPorAno < MIN_KM_POR_ANO) continue;\n\n            registros.push({\n                modelo: modeloDetectado,\n                matricula,\n                km,\n                fechaMat,\n                fechaServ,\n                kmPorMes\n            });\n        }\n    }\n\n    console.log(`✅ Registros válidos: ${registros.length}`);\n\n    /**\n     * AGRUPACIÓN POR MODELO E HITO (ADAPTADO)\n     */\n    const mapa: { [modelo: string]: { [hito: number]: number[] } } = {};\n\n    for (const r of registros) {\n        const hitosModelo = HITOS_POR_MODELO[r.modelo];\n        if (!hitosModelo) continue;\n\n        if (!mapa[r.modelo]) mapa[r.modelo] = {};\n\n        for (const h of hitosModelo) {\n            if (r.km >= h && r.km < h + 3000) {\n                if (!mapa[r.modelo][h]) mapa[r.modelo][h] = [];\n                const meses = r.km / r.kmPorMes;\n                mapa[r.modelo][h].push(meses);\n            }\n        }\n    }\n\n    /**\n     * SALIDA\n     */\n    const salida: (string | number)[][] = [[\"MODELO\", \"HITO (KM)\", \"MEDIA (MESES)\", \"MUESTRAS\"]];\n\n    for (const modelo of MODELOS) {\n        const hitos = HITOS_POR_MODELO[modelo];\n        if (!hitos) continue;\n\n        for (const hito of hitos) {\n            const lista = mapa[modelo] && mapa[modelo][hito] ? mapa[modelo][hito] : [];\n            let media: number;\n            const muestras: number = lista.length;\n\n            if (muestras > 0) {\n                let suma = 0;\n                for (let i = 0; i < lista.length; i++) suma += lista[i];\n                media = suma / muestras;\n            } else {\n                media = (hito / 5000) * 12;\n            }\n\n            salida.push([\n                modelo,\n                hito,\n                Math.round(media * 10) / 10,\n                muestras\n            ]);\n        }\n    }\n\n    let hojaRes = workbook.getWorksheet(\"ResultadosMediasHitos\");\n    if (!hojaRes) {\n        hojaRes = workbook.addWorksheet(\"ResultadosMediasHitos\");\n    } else {\n        const usedRes = hojaRes.getUsedRange();\n        if (usedRes) usedRes.clear();\n    }\n\n    hojaRes\n        .getRange(\"A1\")\n        .getResizedRange(salida.length - 1, salida[0].length - 1)\n        .setValues(salida);\n\n    console.log(`✅ Cálculo completado. Filas generadas: ${salida.length - 1}`);\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}