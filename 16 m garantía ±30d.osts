{"version":"0.3.0","body":"interface Resultado {\n    \"FECHA MATRICULACION\": string;\n    \"N MATRICULA\": string;\n    \"DESCRIPCION\": string;\n    \"FECHA DE SERVICIO\": string;\n    \"KILOMETRAJE ULTIMO SERVICIO\": string | number;\n    \"KILOMETRAJE MANTENIMIENTO\": string | number;\n    \"CODIGO SERVICIO\": string;\n    \"FIN MANTENIMIENTO\": string;\n    \"FECHA EXP GARANTIA\": string;\n    \"INICIO GARANT EXTEND\": string;\n    \"SALUDO\": string;\n    \"TELEFONO\": string;\n    \"EMAIL\": string;\n    \"DIRECCION\": string;\n}\n\nfunction main(workbook: ExcelScript.Workbook): { csvBase64: string; logs: string[] } {\n    const logs: string[] = [];\n    const log = (msg: unknown): void => {\n        const text = typeof msg === \"string\" ? msg : JSON.stringify(msg);\n        console.log(text);\n        logs.push(`[${new Date().toISOString()}] ${text}`);\n    };\n\n    const hoja = workbook.getWorksheet(\"Hoja1\");\n    if (!hoja) throw new Error(\"❌ Hoja 'Hoja1' no encontrada.\");\n\n    const used = hoja.getUsedRange();\n    if (!used) throw new Error(\"❌ No hay datos en la hoja.\");\n\n    const totalCols = used.getColumnCount();\n    const totalRows = used.getRowCount();\n\n    // --------- UTILIDADES ---------\n    const normalizeHeader = (s: unknown): string =>\n        s ? String(s).normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").toLowerCase().trim() : \"\";\n\n    const cleanModelText = (s: unknown): string =>\n        s ? String(s).toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").replace(/[^a-z0-9]/g, \"\") : \"\";\n\n    const normalizePlain = (s: unknown): string =>\n        s ? String(s).toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").trim() : \"\";\n\n    const parseFecha = (v: unknown): Date | null => {\n        if (!v || v === \"--/--/--\") return null;\n\n        if (typeof v === \"number\") {\n            const d = new Date((v - 25569) * 86400 * 1000);\n            return isNaN(d.getTime()) ? null : d;\n        }\n\n        const s = String(v).trim();\n        const iso = Date.parse(s);\n        if (!isNaN(iso)) return new Date(iso);\n\n        const p = s.split(\"/\");\n        if (p.length === 3) {\n            const [d, m, y] = p.map(n => parseInt(n, 10));\n            if (!isNaN(d) && !isNaN(m) && !isNaN(y)) return new Date(y, m - 1, d);\n        }\n\n        return null;\n    };\n\n    // --------- ENCABEZADOS ---------\n    const headerRow = hoja.getRangeByIndexes(0, 0, 1, totalCols).getValues()[0];\n    const headers = headerRow.map(v => String(v ?? \"\"));\n\n    const colContains = (name: string): number =>\n        headers.findIndex(h => normalizeHeader(h).includes(normalizeHeader(name)));\n\n    const colExact = (name: string): number =>\n        headers.findIndex(h => normalizeHeader(h) === normalizeHeader(name));\n\n    const idxMatricula = colContains(\"Nº.matrícula\");\n    const idxDesc = colContains(\"Descripción\");\n    const idxMunicipio = colContains(\"Direccion(3)\");\n    const idxFechaMat = colContains(\"Fecha.matriculación\");\n    const idxFechaExpGarantia = colContains(\"Fecha.exp.garantia\");\n    const idxInicioGarantExtend = colContains(\"Inicio.garant.extend\");\n    const idxFinMant = colContains(\"Fin.mantenimiento\");\n\n    // OJO: aquí usamos igualdad exacta para no confundir Kilometraje y Kilometraje.mantenim\n    const idxKmUltimo = colExact(\"Kilometraje\");\n    const idxKmMantenim = colExact(\"Kilometraje.mantenim\");\n\n    const idxSaludo = colContains(\"Saludo.(tratamiento)\");\n    const idxTelefono = colContains(\"Nº.telefono(4)\");\n    const idxEmail = colContains(\"Direccion.e-mail\");\n\n    const required = [\n        idxMatricula, idxDesc, idxMunicipio, idxFechaMat,\n        idxKmUltimo, idxKmMantenim, idxSaludo, idxTelefono, idxEmail\n    ];\n\n    if (required.some(i => i < 0)) {\n        throw new Error(\"❌ Faltan columnas obligatorias (matrícula/descripcion/municipio/fechas/km/etc).\");\n    }\n\n    const allIndices = [\n        idxMatricula, idxDesc, idxMunicipio, idxFechaMat, idxFechaExpGarantia,\n        idxInicioGarantExtend, idxFinMant, idxKmUltimo, idxKmMantenim,\n        idxSaludo, idxTelefono, idxEmail\n    ];\n\n    const minCol = Math.min(...allIndices);\n    const maxCol = Math.max(...allIndices);\n    const width = maxCol - minCol + 1;\n\n    // --------- VENTANA 15–16 MESES ---------\n    const hoy = new Date();\n\n    const fecha16 = new Date(hoy);\n    fecha16.setMonth(fecha16.getMonth() - 16);\n\n    const fecha15 = new Date(hoy);\n    fecha15.setMonth(fecha15.getMonth() - 15);\n\n    log({\n        hoy: hoy.toISOString().split(\"T\")[0],\n        ventanaDesde: fecha16.toISOString().split(\"T\")[0],\n        ventanaHasta: fecha15.toISOString().split(\"T\")[0]\n    });\n\n    const modelosPermitidos = [\"nmax\", \"xmax125\", \"xmax300\", \"tmax\", \"mt125\", \"mt07\", \"mt09\", \"tenere700\"];\n\n    const municipiosPermitidos = [\n        \"arucas\", \"firgas\", \"galdar\", \"ingenio\", \"moya\", \"las palmas\",\n        \"santa brigida\", \"guia\", \"telde\", \"teror\",\n        \"valleseco\", \"valsequillo\", \"vega de san mateo\"\n    ];\n\n    // --------- PROCESADO ---------\n    const resultadosMap = new Map<string, Resultado>();\n    const CHUNK = 500;\n\n    for (let start = 1; start < totalRows; start += CHUNK) {\n        const rows = Math.min(CHUNK, totalRows - start);\n        const chunk = hoja.getRangeByIndexes(start, minCol, rows, width).getValues() as unknown[][];\n\n        for (const fila of chunk) {\n            const matricula = String(fila[idxMatricula - minCol] ?? \"\").trim();\n            if (!matricula) continue;\n\n            const fechaMat = parseFecha(fila[idxFechaMat - minCol]);\n            if (!fechaMat) continue;\n\n            // 16 meses ≤ FECHA MATRICULACIÓN < 15 meses\n            if (!(fechaMat >= fecha16 && fechaMat < fecha15)) continue;\n\n            const inicioExtRaw = fila[idxInicioGarantExtend - minCol];\n            const inicioExt = String(inicioExtRaw ?? \"\").trim();\n            if (inicioExt && inicioExt !== \"--/--/--\") continue;\n\n            const descClean = cleanModelText(fila[idxDesc - minCol]);\n            if (!modelosPermitidos.some(m => descClean.includes(m))) continue;\n\n            const municipioNorm = normalizePlain(fila[idxMunicipio - minCol]);\n            if (!municipiosPermitidos.some(m => municipioNorm.includes(m))) continue;\n\n            const kmUltRaw = fila[idxKmUltimo - minCol];\n            const kmUlt: string | number =\n                typeof kmUltRaw === \"number\" || typeof kmUltRaw === \"string\"\n                    ? kmUltRaw\n                    : \"\";\n\n            const kmMantRaw = fila[idxKmMantenim - minCol];\n            const kmMant: string | number =\n                typeof kmMantRaw === \"number\" || typeof kmMantRaw === \"string\"\n                    ? kmMantRaw\n                    : \"\";\n\n\n            const fExp = parseFecha(fila[idxFechaExpGarantia - minCol]);\n            const fechaExpGarantia = fExp ? fExp.toISOString().split(\"T\")[0] : \"\";\n\n            const fFin = parseFecha(fila[idxFinMant - minCol]);\n            const fechaFinMant = fFin ? fFin.toISOString().split(\"T\")[0] : \"\";\n\n            const resultado: Resultado = {\n                \"FECHA MATRICULACION\": fechaMat.toISOString().split(\"T\")[0],\n                \"N MATRICULA\": matricula,\n                \"DESCRIPCION\": String(fila[idxDesc - minCol] ?? \"\"),\n                \"FECHA DE SERVICIO\": \"\",\n                \"KILOMETRAJE ULTIMO SERVICIO\": kmUlt,\n                \"KILOMETRAJE MANTENIMIENTO\": kmMant,\n                \"CODIGO SERVICIO\": \"\",\n                \"FIN MANTENIMIENTO\": fechaFinMant,\n                \"FECHA EXP GARANTIA\": fechaExpGarantia,\n                \"INICIO GARANT EXTEND\": inicioExt,\n                \"SALUDO\": String(fila[idxSaludo - minCol] ?? \"\"),\n                \"TELEFONO\": String(fila[idxTelefono - minCol] ?? \"\"),\n                \"EMAIL\": String(fila[idxEmail - minCol] ?? \"\"),\n                \"DIRECCION\": String(fila[idxMunicipio - minCol] ?? \"\")\n            };\n\n            // Si hay varias filas de la misma matrícula, la última del Excel pisará a las anteriores\n            resultadosMap.set(matricula, resultado);\n        }\n    }\n\n    const resultados = Array.from(resultadosMap.values());\n    log(`✅ Resultados obtenidos: ${resultados.length}`);\n\n    if (resultados.length === 0) {\n        throw new Error(\"No hay registros que cumplan los criterios.\");\n    }\n\n    // --------- CSV ---------\n    const headersCSV = [\n        \"FECHA MATRICULACION\",\n        \"N MATRICULA\",\n        \"DESCRIPCION\",\n        \"FECHA DE SERVICIO\",\n        \"KILOMETRAJE ULTIMO SERVICIO\",\n        \"CODIGO SERVICIO\",\n        \"KILOMETRAJE MANTENIMIENTO\",\n        \"FIN MANTENIMIENTO\",\n        \"FECHA EXP GARANTIA\",\n        \"INICIO GARANT EXTEND\",\n        \"SALUDO\",\n        \"TELEFONO\",\n        \"EMAIL\",\n        \"DIRECCION\"\n    ];\n\n    const csvRows: string[] = [headersCSV.join(\";\")];\n\n    for (const r of resultados) {\n        csvRows.push(\n            [\n                r[\"FECHA MATRICULACION\"],\n                r[\"N MATRICULA\"],\n                r[\"DESCRIPCION\"],\n                r[\"FECHA DE SERVICIO\"],\n                r[\"KILOMETRAJE ULTIMO SERVICIO\"],\n                r[\"KILOMETRAJE MANTENIMIENTO\"],\n                r[\"CODIGO SERVICIO\"],\n                r[\"FIN MANTENIMIENTO\"],\n                r[\"FECHA EXP GARANTIA\"],\n                r[\"INICIO GARANT EXTEND\"],\n                r[\"SALUDO\"],\n                r[\"TELEFONO\"],\n                r[\"EMAIL\"],\n                r[\"DIRECCION\"]\n            ]\n                .map(x => String(x ?? \"\").replace(/;/g, \",\"))\n                .join(\";\")\n        );\n    }\n\n    const csvBase64 = base64Encode(csvRows.join(\"\\n\"));\n\n    return { csvBase64, logs };\n}\n\n/* --------- BASE64 --------- */\nfunction base64Encode(str: string): string {\n    const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\";\n    let output = \"\", i = 0;\n    while (i < str.length) {\n        const c1 = str.charCodeAt(i++);\n        const c2 = str.charCodeAt(i++);\n        const c3 = str.charCodeAt(i++);\n        const e1 = c1 >> 2;\n        const e2 = ((c1 & 3) << 4) | (c2 >> 4);\n        const e3 = ((c2 & 15) << 2) | (c3 >> 6);\n        const e4 = c3 & 63;\n        if (isNaN(c2)) output += chars[e1] + chars[e2] + \"==\";\n        else if (isNaN(c3)) output += chars[e1] + chars[e2] + chars[e3] + \"=\";\n        else output += chars[e1] + chars[e2] + chars[e3] + chars[e4];\n    }\n    return output;\n}\n","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"csvBase64\":{\"type\":\"string\"},\"logs\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}